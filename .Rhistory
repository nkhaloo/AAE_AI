) %>%
mutate(
interaction_term = interaction(race, sex),
F1_pred = predict(model_F1, newdata=., exclude=c("s(normalized_time,speaker)"), newdata.guaranteed=TRUE),
F2_pred = predict(model_F2, newdata=., exclude=c("s(normalized_time,speaker)"), newdata.guaranteed=TRUE)
)
# Plot formant trajectories clearly showing interaction explicitly
plot <- ggplot(new_data, aes(x=F2_pred, y=F1_pred, color=sex, linetype=race, group=interaction(race,sex))) +
geom_path(arrow=arrow(angle=20,length=unit(0.1,"inches"),type="closed"), linewidth=1) +
scale_x_reverse(name="F2 (Bark)") +
scale_y_reverse(name="F1 (Bark)") +
theme_classic() +
ggtitle(paste("Formant trajectory (Race × Sex) for vowel /", v, "/", sep="")) +
theme(legend.position="right")
print(plot)
}
library(stringr)
# 1. Original word list
wordlist <- c("peat", "seat", "feet", "deep", "beat", "seek", "teeth", "peak", "sheet", "keep", "beep", "cheek",
"kit", "ship", "tip", "fit", "pit", "pick", "tick", "sit", "chip", "sip", "bit", "dip",
"tape", "cake", "cape", "date", "gate", "take", "safe", "fake", "fate", "shape", "bait", "sake",
"dead", "get", "beg", "bet", "debt", "peck", "deck", "pet", "pep", "vet", "jet", "bed",
"gap", "pack", "tap", "sat", "bat", "pat", "cap", "tat", "cat", "fat", "zap", "tax",
"dot", "got", "pox", "tot", "jock", "shot", "sock", "dock", "cop", "pot", "not", "box",
"soup", "duke", "dupe", "food", "boot", "loop", "kook", "tube", "tooth", "suit", "shoot", "goop",
"caught", "bought", "taught", "thought", "fought", "sought", "moss", "boss", "talk", "loss", "toss",
"walk")
# 2. Full passage text
passage <- tolower("As the afternoon sun warmed the deck, I decided to sit outside and eat a slice of cake. Nearby, a playful cat chased a fallen chip under my chair. Earlier, I'd checked the flowerbed for weeds and found some rich peat perfect for the plants. Taking a sip of hot soup, I heard a distant beep from a delivery truck pulling up by the garden gate.
On the dock by the lake, someone had dropped their cap, forgotten near an old wooden box. A small jet plane buzzed overhead, causing the ducks to scatter in panic. Feeling relaxed, I kicked off my boot, dipped my feet in the cool water, and watched the clouds take shape overhead.
Later, I decided to take a walk along the shoreline. Passing the trees draped with soft moss, I watched a fisherman toss his bait into the water, hoping to avoid getting it caught on the rocks. He'd already caught several fish, which he planned to fry later for his dinner.
Back inside, I carefully taped up a torn sheet and found an old tape with vintage music. I turned it on, filling the room with nostalgic sounds. A pot of stew simmered on the stove, next to a kettle ready to whistle at the first tick of boiling water. Checking the fridge, I noted a gap in my supplies and added food and drinks to my shopping list.
In the living room, a comedy played quietly on TV. The main character, dressed in a business suit, tripped over a toy ship, fell dramatically, and made everyone laugh. I found the remote under a cushion, and after flipping channels, settled on a nature documentary about how animals seek shelter when the weather changes suddenly.
As the evening grew darker, I lit a candle, careful not to get wax on my new cape. My loyal pet, a gentle dog, curled beside me, eager for attention. He had a slight limp, so a trip to the vet was scheduled for tomorrow. Recalling our earlier training session, I remembered how he eagerly learned to beg for treats.
In the kitchen, the clock's soft tick reminded me it was getting late. I made some tea, trying not to dip my sleeve accidentally. Outside, streetlights cast a comforting glow. The day had been simple, but full. Tomorrow I'd have to pay the tax and check on a late utility bill to avoid falling further into debt.
I glanced at the calendar and realized I nearly forgot an important date—my neighbor's birthday. I'd already bought a thoughtful gift, safely stored in the closet. Content with my preparations, I finally climbed into bed, thinking about everything I'd been taught over the years, grateful for life's simple pleasures. Just as sleep approached, a soft rain began to gently tap on the roof, bringing a peaceful end to my day.
The next morning, I planned to bake bread and set the timer carefully to avoid overcooking and turning it into a burnt tot. I carefully arranged everything I needed: flour, yeast, and a pinch of salt. With confidence, I vowed to keep improving my baking skills until they were as sharp as my tooth.")
# 3. Tokenize and count
tokens <- str_extract_all(passage, "\\b[a-z]+\\b")[[1]]
counts <- table(factor(tokens, levels = wordlist))
# 4. Check for missing or duplicated words
missing <- names(counts[counts == 0])
duplicates <- names(counts[counts > 1])
# 5. Output results
if (length(missing) == 0 && length(duplicates) == 0) {
cat("✅ All 84 words are used exactly once.\n")
} else {
if (length(missing) > 0) {
cat("❌ Missing words:\n")
print(missing)
}
if (length(duplicates) > 0) {
cat("⚠️ Duplicated words:\n")
print(duplicates)
}
}
